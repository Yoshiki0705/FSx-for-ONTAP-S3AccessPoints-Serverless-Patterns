# samconfig.toml.example — flexcache-anycast-dr
#
# 使用方法:
#   1. このファイルを samconfig.toml にコピー
#   2. <PLACEHOLDER> を実際の値に置き換え
#   3. sam deploy を実行
#
# 注意: samconfig.toml は .gitignore に含まれています

version = 0.1

[default.deploy.parameters]
stack_name = "fsxn-s3ap-flexcache-anycast-dr"
resolve_s3 = true
s3_prefix = "fsxn-s3ap-flexcache-anycast-dr"
region = "ap-northeast-1"
confirm_changeset = true
capabilities = "CAPABILITY_NAMED_IAM"
disable_rollback = false

parameter_overrides = [
    "Environment=demo",
    "SimulationMode=true",
    "CacheEndpoints=cache-a.example.com,cache-b.example.com",
    "S3AccessPointAlias=",
    "OntapSecretName=fsxn/ontap-credentials",
    "NotificationEmail=",
    "HealthCheckIntervalMinutes=5",
    "EnableVpcEndpoints=false",
    "EnableCloudWatchAlarms=true",
]

[default.build.parameters]
cached = true
parallel = true
