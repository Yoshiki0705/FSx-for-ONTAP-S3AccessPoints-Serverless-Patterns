# samconfig.toml.example — genai-quick-agentic-workspace (UC30)
#
# 使用方法:
#   1. このファイルを samconfig.toml にコピー
#   2. <PLACEHOLDER> を実際の値に置き換え
#   3. sam deploy を実行
#   4. Amazon Quick コンソールでデータソース接続（Quick Index / Quick Sight）を構成
#
# 注意: samconfig.toml は .gitignore に含まれています

version = 0.1

[default.deploy.parameters]
stack_name = "fsxn-s3ap-genai-quick-agentic-workspace"
resolve_s3 = true
s3_prefix = "fsxn-s3ap-genai-quick-agentic-workspace"
region = "ap-northeast-1"
confirm_changeset = true
capabilities = "CAPABILITY_NAMED_IAM"
disable_rollback = false

parameter_overrides = [
    "S3AccessPointAlias=<YOUR_S3AP_ALIAS>-ext-s3alias",
    "S3AccessPointName=<YOUR_S3AP_NAME>",
    "WorkspacePrefix=quick-workspace/",
    "BedrockLlmModelId=apac.amazon.nova-pro-v1:0",
    "QuickDataSourcePrincipal=",
    "PrepScheduleExpression=rate(1 hour)",
    "NotificationEmail=",
]

[default.build.parameters]
cached = true
parallel = true
