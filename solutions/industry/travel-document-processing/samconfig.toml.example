# SAM CLI 設定ファイルテンプレート
# cp samconfig.toml.example samconfig.toml して使用

version = 0.1

[default.deploy.parameters]
stack_name = "fsxn-s3ap-travel"
region = "ap-northeast-1"
confirm_changeset = true
capabilities = "CAPABILITY_NAMED_IAM"
parameter_overrides = [
    "S3AccessPointAlias=YOUR_AP_ALIAS-ext-s3alias",
    "S3AccessPointOutputAlias=YOUR_OUTPUT_AP_ALIAS-ext-s3alias",
    "OntapSecretName=YOUR_SECRET_NAME",
    "OntapManagementIp=10.0.0.1",
    "SvmUuid=YOUR_SVM_UUID",
    "VpcId=vpc-xxxxxxxx",
    "PrivateSubnetIds=subnet-aaaa,subnet-bbbb",
    "PrivateRouteTableIds=rtb-xxxx,rtb-yyyy",
    "NotificationEmail=your@email.com",
    "CrossRegionTextractRegion=us-east-1",
    "ReservationDocPrefix=reservations/",
    "FacilityImagePrefix=facility-inspections/",
]

[default.build.parameters]
use_container = false
