version = 0.1
[default.deploy.parameters]
stack_name = "fsxn-ops-cost-optimization"
resolve_s3 = true
region = "ap-northeast-1"
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
parameter_overrides = [
    "FileSystemIds=fs-0123456789abcdef0",
    "AutomationLevel=0",
    "DemoMode=true",
    "ScheduleExpression=rate(1 day)",
]
