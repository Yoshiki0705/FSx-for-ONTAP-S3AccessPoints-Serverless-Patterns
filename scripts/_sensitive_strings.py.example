"""Environment-specific sensitive literals for mask verification and redaction.

COPY THIS FILE to `_sensitive_strings.py` and fill in with your actual
account-specific values. The `_sensitive_strings.py` file is gitignored
and must NEVER be committed.

Used by:
- `mask_uc_demos.py` to verify PNG metadata does not contain these literals
- `_check_sensitive_leaks.py` to scan images for leaked text
- `redact_sensitive.py` to replace sensitive values in tracked files
"""

# Each string must be an exact substring to search for in PNG binary metadata
# and in rendered text regions. Fill in with your own environment's values.
SENSITIVE_STRINGS: tuple[str, ...] = (
    # AWS account ID
    # "123456789012",
    # FSx volume / file system / SVM IDs
    # "fsvol-xxxxxxxxxxxxxxxxx",
    # "fs-xxxxxxxxxxxxxxxxx",
    # "svm-xxxxxxxxxxxxxxxxx",
    # VPC / subnet / security group IDs
    # "vpc-xxxxxxxxxxxxxxxxx",
    # "subnet-xxxxxxxxxxxxxxxxx",
    # "sg-xxxxxxxxxxxxxxxxx",
    # ONTAP management IP, EC2 IPs
    # "10.0.x.x",
    # Notification email
    # "you@example.com",
    # S3 Access Point alias
    # "your-s3ap-alias-ext-s3alias",
)

# Redaction rules for `redact_sensitive.py`
# Format: (regex_pattern, replacement_in_scripts, replacement_in_docs)
REDACTION_RULES: list[tuple[str, str, str]] = [
    # AWS Account ID
    # (r"123456789012", r"<ACCOUNT_ID>", r"<ACCOUNT_ID>"),
    # FSx Volume IDs
    # (r"fsvol-0xxxxxxxxxxxxxxxx", r"<FSX_VOLUME_ID>", r"<FSX_VOLUME_ID>"),
    # FSx File System ID
    # (r"fs-0xxxxxxxxxxxxxxxx", r"<FSX_FILE_SYSTEM_ID>", r"<FSX_FILE_SYSTEM_ID>"),
    # SVM ID
    # (r"svm-0xxxxxxxxxxxxxxxx", r"<SVM_ID>", r"<SVM_ID>"),
    # SVM UUID
    # (r"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx", r"<SVM_UUID>", r"<SVM_UUID>"),
    # VPC ID
    # (r"vpc-0xxxxxxxxxxxxxxxx", r"<VPC_ID>", r"<VPC_ID>"),
    # Security Group IDs
    # (r"sg-0xxxxxxxxxxxxxxxx", r"<SG_ID>", r"<SG_ID>"),
    # Subnet IDs
    # (r"subnet-0xxxxxxxxxxxxxxxx", r"<SUBNET_ID>", r"<SUBNET_ID>"),
    # Route Table IDs
    # (r"rtb-0xxxxxxxxxxxxxxxx", r"<ROUTE_TABLE_ID>", r"<ROUTE_TABLE_ID>"),
    # ONTAP Management IP (escape dots for regex)
    # (r"10\.0\.x\.x", r"<ONTAP_MGMT_IP>", r"<ONTAP_MGMT_IP>"),
    # EC2 Public IP
    # (r"x\.x\.x\.x", r"<EC2_PUBLIC_IP>", r"<EC2_PUBLIC_IP>"),
    # EC2 Instance ID
    # (r"i-0xxxxxxxxxxxxxxxx", r"<EC2_INSTANCE_ID>", r"<EC2_INSTANCE_ID>"),
    # Notification email
    # (r"you@example\.com", r"<NOTIFICATION_EMAIL>", r"<NOTIFICATION_EMAIL>"),
    # S3 Access Point alias
    # (r"your-s3ap-alias-ext-s3alias", r"<S3_AP_ALIAS>", r"<S3_AP_ALIAS>"),
]
