# samconfig.toml.example — life-sciences-research
#
# 使用方法:
#   1. このファイルを samconfig.toml にコピー
#   2. <PLACEHOLDER> を実際の値に置き換え
#   3. sam deploy を実行
#
# 注意: samconfig.toml は .gitignore に含まれています

version = 0.1

[default.deploy.parameters]
stack_name = "fsxn-s3ap-life-sciences-research"
resolve_s3 = true
s3_prefix = "fsxn-s3ap-life-sciences-research"
region = "ap-northeast-1"
confirm_changeset = true
capabilities = "CAPABILITY_NAMED_IAM"
disable_rollback = false

parameter_overrides = [
    "S3AccessPointAlias=<YOUR_S3AP_ALIAS>-ext-s3alias",
    "S3AccessPointName=<YOUR_S3AP_NAME>",
    "OntapSecretName=fsxn/ontap-credentials",
    "BedrockModelId=amazon.nova-pro-v1:0",
    "ScheduleExpression=rate(1 hour)",
    "NotificationEmail=",
    "OutputDestination=STANDARD_S3",
]

[default.build.parameters]
cached = true
parallel = true
