# samconfig.toml.example — content-edge-delivery
#
# 使用方法:
#   1. このファイルを samconfig.toml にコピー
#   2. <PLACEHOLDER> を実際の値に置き換え
#   3. sam deploy を実行
#
# 注意: samconfig.toml は .gitignore に含まれています

version = 0.1

[default.deploy.parameters]
stack_name = "fsxn-content-edge-delivery"
resolve_s3 = true
s3_prefix = "fsxn-content-edge-delivery"
region = "ap-northeast-1"
confirm_changeset = true
capabilities = "CAPABILITY_NAMED_IAM"
disable_rollback = false

parameter_overrides = [
    "S3AccessPointAlias=<YOUR_S3AP_ALIAS>-ext-s3alias",
    "S3AccessPointOutputAlias=<YOUR_OUTPUT_S3AP_ALIAS>-ext-s3alias",
    "DeliveryMode=PUBLISH_PUSH",
    "CDNTarget=CLOUDFRONT",
    "ApprovedPrefix=delivery-approved/",
    "SuffixFilter=",
    "DemoMode=true",
    "ExternalStoreEndpoint=",
    "ExternalStoreBucket=",
    "ExternalStoreSecretName=",
    "DataClassification=PUBLIC",
    "RedactClientIp=true",
    "NotificationEmail=<YOUR_EMAIL>",
    "ScheduleExpression=rate(1 hour)",
    "TriggerMode=POLLING",
    "EnableCloudFront=false",
    "EnableCloudWatchAlarms=false",
    "EnableXRayTracing=true",
    "LogRetentionInDays=90",
]

[default.build.parameters]
cached = true
parallel = true
