# The deploy/cleanup/verify scripts were historically committed with account IDs.
# Going forward they must read values from environment variables only; keep the
# local copies gitignored to prevent accidental re-commit with hardcoded values.

# Screenshots — originals contain account info, masked versions are safe to publish
docs/screenshots/originals/
# docs/screenshots/masked/ is tracked (safe to publish)

